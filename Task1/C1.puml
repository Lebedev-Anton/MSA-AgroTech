@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Context.puml

Person(operator, "Оператор фермы", "Дежурный сотрудник на месте")
Person(office_user, "Пользователь\Сотрудник офиса", "Пользователь центрального сервера")

System(central, "Центральный сервер (Cloud)", "Агрегация данных со всех ферм")

System_Boundary(farm, "Ферма N") {
    System(agent, "Агент фермы (Edge Server)", "Локальный оркестратор, кэш, автономная работа")
    System(video_analytics, "Видеоаналитика (AI)", "Анализ поведения, задавливания, подсчёт поголовья")
    System(iot_controllers, "Контроллеры IoT", "Управление кормушками, поилками, фильтрацией воды")
    System(stockroom, "Управление складом", "Сбор складских заказов")
}
 
Rel(operator, agent, "Получает уведомления и управляет, REST/WebSocket", "Локальная сеть")
Rel(agent, video_analytics, "Отправляет видеопоток, получает события")
Rel(agent, iot_controllers, "Отправляет команды управления, опрашивает статусы")
Rel(agent, stockroom, "Опрашивает метрики")

Rel(agent, central, "Синхронизирует данные (задержка ≤10 мин), отправляет метрики", "HTTP, ELT")
Rel(central, office_user, "Предоставляет панель управления и отчёты, HTTPS")
@enduml